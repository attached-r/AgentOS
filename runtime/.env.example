# ==============================================================================
# AgentOS Runtime 环境变量配置
# ==============================================================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ==============================================================================

# ── FastAPI 服务配置 ──────────────────────────────────────────────
RUNTIME_HOST=0.0.0.0
RUNTIME_PORT=8000
RUNTIME_DEBUG=false
LOG_LEVEL=INFO

# ── LLM 默认配置 ──────────────────────────────────────────────────
# 默认供应商和模型（SimpleAgent 未指定 provider 时使用）
DEFAULT_MODEL_PROVIDER=openai
DEFAULT_MODEL_NAME=gpt-4o-mini
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096

# ── LLM 通用凭据（作为兜底，建议使用各供应商专用变量） ──────────
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1

# ── 各供应商 API Key ──────────────────────────────────────────────
# 设置对应供应商的环境变量后，LLMClient 会自动读取
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# MODELSCOPE_API_KEY=ms-xxx
# ZHIPU_API_KEY=xxx
# ── Ollama 不需要 API Key ─────────────────────────────────────────

# ── 后端 API 地址（Runtime → Backend 回调）────────────────────────
# 用于记忆持久化和 RAG 检索，指向 SpringBoot 后端
BACKEND_BASE_URL=http://localhost:8080

# ── ReAct Agent ───────────────────────────────────────────────────
# 单轮推理-行动循环的最大步数
REACT_MAX_STEPS=10

# ── Redis 工作记忆（V2.1 升级）─────────────────────────────────────
# 短期记忆改用 Redis 存储，替代 V2 内存 List 方案
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_WM_DB=1                              # 工作记忆独立 db，与后端 Redis 物理隔离
# REDIS_WM_TTL=3600                          # 工作记忆 TTL（秒），默认 1 小时
# REDIS_WM_CAPACITY=100                      # 单个 Agent 工作记忆容量上限

# ── MCP 超时（秒）─────────────────────────────────────────────────
MCP_CONNECTION_TIMEOUT=30
MCP_READ_TIMEOUT=60
